---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title?: string
  description?: string
  image?: string | null
  type?: 'website' | 'article'
  publishedTime?: string
}

const { title, description, image, type, publishedTime } = Astro.props
---

<BaseLayout title={title} description={description} image={image} type={type} publishedTime={publishedTime}>
  <slot />
</BaseLayout>
