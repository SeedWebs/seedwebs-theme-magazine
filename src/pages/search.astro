---
export const prerender = false

import BlogLayout from '@/layouts/BlogLayout.astro'
import PostGrid from '@/components/blog/PostGrid.astro'
import { getPosts, getCategories, getTags } from '@/lib/api'
import { excerpt } from '@/lib/utils'
import type { Post } from '@/lib/types'

const query = Astro.url.searchParams.get('q')?.trim() || ''

let results: Post[] = []
if (query) {
  // Fetch all posts and filter client-side (API doesn't have search param yet)
  const { posts } = await getPosts({ perPage: 100 })
  const q = query.toLowerCase()
  results = posts.filter(p =>
    p.title.toLowerCase().includes(q) ||
    excerpt(p.body, 500).toLowerCase().includes(q) ||
    p.categories.some(c => c.name.toLowerCase().includes(q)) ||
    p.tags.some(t => t.name.toLowerCase().includes(q))
  )
}

const [categories, tags] = await Promise.all([getCategories(), getTags()])
---

<BlogLayout
  title={query ? `Search: ${query}` : 'Search'}
  categories={categories}
  tags={tags}
>
  <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">Search</h1>

  {/* Search form */}
  <form method="get" action="/search" class="mb-8">
    <div class="flex gap-2">
      <input
        type="text"
        name="q"
        value={query}
        placeholder="Search posts..."
        class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:placeholder:text-gray-500"
        autofocus
      />
      <button
        type="submit"
        class="rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-fg transition-colors hover:opacity-90"
      >
        Search
      </button>
    </div>
  </form>

  {/* Results */}
  {query && (
    <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">
      {results.length} result{results.length !== 1 ? 's' : ''} for "{query}"
    </p>
  )}

  {results.length > 0 ? (
    <PostGrid posts={results} />
  ) : query ? (
    <p class="text-gray-500 dark:text-gray-400">No posts found. Try a different search term.</p>
  ) : null}
</BlogLayout>
