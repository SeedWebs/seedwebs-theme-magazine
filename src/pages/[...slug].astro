---
import PageLayout from '@/layouts/PageLayout.astro'
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro'
import PostBody from '@/components/blog/PostBody.astro'
import { getPages, getPage } from '@/lib/api'

export async function getStaticPaths() {
  const pages = await getPages()
  return pages.map(p => ({
    params: { slug: p.slug },
  }))
}

const page = await getPage(Astro.params.slug!)
if (!page) return Astro.redirect('/404')
---

<PageLayout
  title={page.seo_title || page.title}
  description={page.seo_description || undefined}
  image={page.featured_image}
>
  <main class="mx-auto max-w-3xl px-4 py-8 md:py-12">
    <h1 class="mb-6 text-3xl font-bold text-gray-900 md:text-4xl dark:text-white">
      {page.title}
    </h1>

    {page.featured_image && (
      <div class="mb-8 overflow-hidden rounded-md">
        <ResponsiveImage
          src={page.featured_image}
          srcMobile={page.featured_image_mobile}
          alt={page.title}
          class="w-full"
          sizes="(max-width: 768px) 100vw, 768px"
          loading="eager"
        />
      </div>
    )}

    <PostBody html={page.body} />
  </main>
</PageLayout>
