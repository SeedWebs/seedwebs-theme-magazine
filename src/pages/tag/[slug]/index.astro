---
import BlogLayout from '@/layouts/BlogLayout.astro'
import PostGrid from '@/components/blog/PostGrid.astro'
import Pagination from '@/components/layout/Pagination.astro'
import { getPosts, getCategories, getTags } from '@/lib/api'

export async function getStaticPaths() {
  const tags = await getTags()
  return tags.map(tag => ({
    params: { slug: tag.slug },
    props: { tag },
  }))
}

const { tag } = Astro.props
const { posts, meta } = await getPosts({ page: 1, tag: tag.slug })
const [categories, tags] = await Promise.all([getCategories(), getTags()])
const recentPosts = posts.slice(0, 5)
---

<BlogLayout
  title={`#${tag.name}`}
  description={`Posts tagged with ${tag.name}`}
  recentPosts={recentPosts}
  categories={categories}
  tags={tags}
>
  <h1 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white">
    Tag: <span class="text-primary">#{tag.name}</span>
  </h1>
  {posts.length > 0 ? (
    <>
      <PostGrid posts={posts} />
      <Pagination currentPage={1} totalPages={meta.total_pages} basePath={`/tag/${tag.slug}`} />
    </>
  ) : (
    <p class="text-gray-500 dark:text-gray-400">No posts found with this tag.</p>
  )}
</BlogLayout>
