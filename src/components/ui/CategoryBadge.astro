---
import type { Category } from '@/lib/types'
import { categoryUrl } from '@/lib/utils'

interface Props {
  category: Category
  size?: 'sm' | 'md'
}

const { category, size = 'sm' } = Astro.props

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
}
---

<a
  href={categoryUrl(category.slug)}
  class:list={[
    'inline-block rounded-full bg-primary/10 font-medium text-primary transition-colors hover:bg-primary/20',
    sizeClasses[size],
  ]}
>
  {category.name}
</a>
